+void llama_rn_context_completion::emitPromptProgress(int32_t processed, int32_t total) {
+    if (!on_prompt_progress_callback) {
+        return;
+    }
+
+    if (total <= 0) {
+        on_prompt_progress_callback(100.0f, 0, 0);
+        last_prompt_progress = 100;
+        return;
+    }
+
+    const int32_t clamped_processed = std::max(0, std::min(processed, total));
+    const int percentage = std::max(
+        0,
+        std::min(100, (int) std::round((double) clamped_processed * 100.0 / (double) total))
+    );
+
+    if (percentage == last_prompt_progress) {
+        return;
+    }
+
+    last_prompt_progress = percentage;
+    on_prompt_progress_callback((float) percentage, clamped_processed, total);
+}
